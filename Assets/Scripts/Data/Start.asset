    _text: "\u0413\u0435\u043D \u0432\u043D\u0435\u0434\u0440\u044F\u0435\u0442\u0441\u044F
      \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u044D\u0442\u0430\u043F\u043E\u0432:"
