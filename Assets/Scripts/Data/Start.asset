  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "Agrobacterium tumefaciens \u2014 \u044D\u0442\u043E \u043F\u0430\u043B\u043E\u0447\u043A\u043E\u0432\u0438\u0434\u043D\u0430\u044F
      \u0433\u0440\u0430\u043C\u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
      \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
      \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0432\u043E\u0437\u0431\u0443\u0434\u0438\u0442\u0435\u043B\u0435\u043C
      \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
      \u0440\u0430\u043A\u0430 \u0443 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0439."
