  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041E\u0431\u044B\u0447\u043D\u043E \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
      \u0430\u043C\u043C\u043E\u043D\u0438\u0439\u043D\u043E\u0433\u043E \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442 \u0430\u043C\u043C\u043E\u043D\u0438\u0439\u043D\u044B\u0435
      \u0441\u043E\u043B\u0438, \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
      \u0430\u043C\u043C\u043E\u043D\u0438\u0439\u043D\u044B\u0439 \u0445\u043B\u043E\u0440\u0438\u0434
      \u0438\u043B\u0438 \u0430\u043C\u043C\u043E\u043D\u0438\u0439\u043D\u044B\u0439
      \u0441\u0443\u043B\u044C\u0444\u0430\u0442.\r"
