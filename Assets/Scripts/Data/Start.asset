  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
      \u043E\u0442\u0434\u0435\u043B\u0438\u0442\u044C \u0447\u0438\u0441\u0442\u0443\u044E
      \u0414\u041D\u041A \u0438\u043B\u0438 \u0420\u041D\u041A \u043E\u0442 \u0431\u0435\u043B\u043A\u043E\u0432
      \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u043C\u043E\u043B\u0435\u043A\u0443\u043B."
    Red: 1
    Green: 1
