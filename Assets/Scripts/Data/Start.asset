  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0410\u043C\u043C\u043E\u043D\u0438\u0439\u043D\u044B\u0435 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
      - \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044E\u0442
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0439 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A
      \u0430\u0437\u043E\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F \u0434\u043B\u044F \u0441\u0438\u043D\u0442\u0435\u0437\u0430
      \u0431\u0435\u043B\u043A\u043E\u0432 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445
      \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u044B\u0445 \u043A\u043E\u043C\u043F\u043E\u043D\u0435\u043D\u0442\u043E\u0432.\r"
