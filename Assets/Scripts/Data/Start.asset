  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
      \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430 \u0441\u0432\u043E\u0439\u0441\u0442\u0432
      \u0433\u0435\u043D\u0430 Bt \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442
      \u0432 \u0441\u0435\u0431\u044F \u043A\u0430\u043A \u043C\u043E\u043B\u0435\u043A\u0443\u043B\u044F\u0440\u043D\u044B\u0435
      \u0438 \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u044B\u0435 \u043C\u0435\u0442\u043E\u0434\u044B,
      \u0442\u0430\u043A \u0438 \u043F\u043E\u043B\u0435\u0432\u044B\u0435 \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F,
      \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0443\u0447\u0451\u043D\u044B\u043C
      \u0443\u0431\u0435\u0434\u0438\u0442\u044C\u0441\u044F \u0432 \u0435\u0433\u043E
      \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
      \u0438 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438."
