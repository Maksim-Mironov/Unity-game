  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0414\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0441\u0432\u043E\u0439\u0441\u0442\u0432
      \u0433\u0435\u043D\u0430 Bt, \u043E\u0442\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0433\u043E
      \u043E\u0442 \u043C\u0438\u043A\u0440\u043E\u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0430,
      \u043D\u0430 \u043F\u0440\u0438\u0433\u043E\u0434\u043D\u043E\u0441\u0442\u044C,
      \u0443\u0447\u0451\u043D\u044B\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u044F\u0442
      \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u044D\u0442\u0430\u043F\u043E\u0432:"
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041A\u043B\u043E\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
      \u0433\u0435\u043D\u0430: \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0439
      \u0433\u0435\u043D (\u043E\u0431\u044B\u0447\u043D\u043E \u043A\u043E\u0434\u0438\u0440\u0443\u044E\u0449\u0438\u0439
      \u0442\u043E\u043A\u0441\u0438\u043D, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u0443\u0431\u0438\u0432\u0430\u0435\u0442 \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u044B\u0445)
      \u043A\u043B\u043E\u043D\u0438\u0440\u0443\u0435\u0442\u0441\u044F \u0432 \u0432\u0435\u043A\u0442\u043E\u0440,
      \u0432\u0435\u043A\u0442\u043E\u0440 \u2014 \u043C\u043E\u043B\u0435\u043A\u0443\u043B\u0430
      \u043D\u0443\u043A\u043B\u0435\u0438\u043D\u043E\u0432\u043E\u0439 \u043A\u0438\u0441\u043B\u043E\u0442\u044B,
      \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E \u0414\u041D\u041A,
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u0430\u044F \u0432
      \u0433\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u0438
      \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0438 \u0433\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430 \u0432\u043D\u0443\u0442\u0440\u044C
      \u043A\u043B\u0435\u0442\u043A\u0438, \u0442\u0430\u043A\u043E\u0439 \u043A\u0430\u043A
      \u043F\u043B\u0430\u0437\u043C\u0438\u0434\u0430, \u0434\u043B\u044F \u0435\u0433\u043E
      \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0433\u043E \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F."
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u042D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u044F \u0433\u0435\u043D\u0430:
      \u0413\u0435\u043D \u0432\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u0432 \u043C\u043E\u0434\u0435\u043B\u044C\u043D\u044B\u0439 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C
      \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
      (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0432 \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u0438,
      \u0434\u0440\u043E\u0436\u0436\u0438 \u0438\u043B\u0438 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F).
      \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C,
      \u043A\u0430\u043A \u0433\u0435\u043D \u0431\u0443\u0434\u0435\u0442 \u0432\u0435\u0441\u0442\u0438
      \u0441\u0435\u0431\u044F \u0432 \u043D\u043E\u0432\u043E\u0439 \u0441\u0440\u0435\u0434\u0435
      \u0438 \u043A\u0430\u043A \u043E\u043D \u0431\u0443\u0434\u0435\u0442 \u044D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F. "
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0410\u043D\u0430\u043B\u0438\u0437 \u044D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u0438:
      \u0423\u0447\u0451\u043D\u044B\u0435 \u0438\u0437\u0443\u0447\u0430\u044E\u0442
      \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u044D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u0438
      \u0433\u0435\u043D\u0430 \u043F\u0440\u0438 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
      \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
      \u043C\u0435\u0442\u043E\u0434\u044B."
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
      \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F: \u041F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442\u0441\u044F
      \u0442\u043E\u043A\u0441\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0430,
      \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u043E\u0433\u043E \u043F\u043E\u0441\u043B\u0435
      \u044D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u0438 \u0433\u0435\u043D\u0430.
      \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435
      \u043C\u043E\u0436\u043D\u043E \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043D\u0430 \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u044B\u0445, \u0447\u0442\u043E\u0431\u044B
      \u043E\u0446\u0435\u043D\u0438\u0442\u044C \u0435\u0433\u043E \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
      \u0432 \u0431\u043E\u0440\u044C\u0431\u0435 \u0441 \u0432\u0440\u0435\u0434\u0438\u0442\u0435\u043B\u044F\u043C\u0438. "
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041E\u0446\u0435\u043D\u043A\u0430 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438:
      \u041F\u0440\u043E\u0432\u043E\u0434\u044F\u0442\u0441\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
      \u043D\u0430 \u0442\u043E\u043A\u0441\u0438\u0447\u043D\u043E\u0441\u0442\u044C
      \u0434\u043B\u044F \u0434\u0440\u0443\u0433\u0438\u0445 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u043E\u0432,
      \u0447\u0442\u043E\u0431\u044B \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C,
      \u0447\u0442\u043E \u0433\u0435\u043D \u043D\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
      \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438 \u0434\u043B\u044F \u043D\u0435\u0446\u0435\u043B\u0435\u0432\u044B\u0445
      \u0432\u0438\u0434\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0438 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445. "
    Red: 1
