  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0410\u043D\u0430\u043B\u0438\u0437 \u0438 \u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435
      - \u043F\u043E\u0441\u043B\u0435 \u044D\u043A\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0438
      \u0438 \u043E\u0447\u0438\u0441\u0442\u043A\u0438 \u043D\u0443\u043A\u043B\u0435\u0438\u043D\u043E\u0432\u044B\u0435
      \u043A\u0438\u0441\u043B\u043E\u0442\u044B \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C
      \u043F\u043E\u0434\u0432\u0435\u0440\u0436\u0435\u043D\u044B \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u043C\u0443
      \u0430\u043D\u0430\u043B\u0438\u0437\u0443, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
      \u041F\u0426\u0420 (\u043F\u043E\u043B\u0438\u043C\u0435\u0440\u0430\u0437\u043D\u0430\u044F
      \u0446\u0435\u043F\u043D\u0430\u044F \u0440\u0435\u0430\u043A\u0446\u0438\u044F),
      \u0441\u0435\u043A\u0432\u0435\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
      \u0438 \u0434\u0440\u0443\u0433\u0438\u043C \u043C\u0435\u0442\u043E\u0434\u0430\u043C
      \u043C\u043E\u043B\u0435\u043A\u0443\u043B\u044F\u0440\u043D\u043E\u0439 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438."
    Red: 1
    Green: 1
