  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0426\u0438\u0442\u0440\u0430\u0442 - \u043E\u0440\u0433\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u043A\u0438\u0441\u043B\u043E\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
      \u0441\u043B\u0443\u0436\u0438\u0442 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u043C
      \u0443\u0433\u043B\u0435\u0440\u043E\u0434\u0430 \u0434\u043B\u044F \u043C\u0438\u043A\u0440\u043E\u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u043E\u0432.
      \u0411\u0430\u043A\u0442\u0435\u0440\u0438\u0438, \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0435
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0446\u0438\u0442\u0440\u0430\u0442
      \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430
      \u0443\u0433\u043B\u0435\u0440\u043E\u0434\u0430, \u043E\u0431\u044B\u0447\u043D\u043E
      \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u044E\u0442 \u0435\u0433\u043E \u0432
      \u043C\u0435\u0442\u0430\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
      \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430\u0445, \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044F
      \u0435\u0433\u043E \u0432 \u0434\u0440\u0443\u0433\u0438\u0435 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F.\r"
