  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430 \u043E\u0431\u0440\u0430\u0437\u0446\u0430
      - \u043F\u0435\u0440\u0435\u0434 \u043D\u0430\u0447\u0430\u043B\u043E\u043C
      \u0440\u0430\u0431\u043E\u0442\u044B \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
      \u043E\u0431\u0440\u0430\u0437\u0446\u044B \u043F\u043E\u0434\u0433\u043E\u0442\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0442\u0441\u044F
      \u0434\u043B\u044F \u044D\u043A\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0438.
      \u042D\u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u0432\u043A\u043B\u044E\u0447\u0430\u0442\u044C
      \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u0435 \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u044B\u0445
      \u0441\u0442\u0435\u043D\u043E\u043A \u0438 \u043C\u0435\u043C\u0431\u0440\u0430\u043D,
      \u0447\u0442\u043E\u0431\u044B \u0432\u044B\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C
      \u043D\u0443\u043A\u043B\u0435\u0438\u043D\u043E\u0432\u044B\u0435 \u043A\u0438\u0441\u043B\u043E\u0442\u044B."
