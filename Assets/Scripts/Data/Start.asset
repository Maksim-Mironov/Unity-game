    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
      \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
      \u043C\u043E\u0436\u043D\u043E \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C
      \u0433\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043C\u043E\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0435
      \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0442 \u043D\u043E\u0432\u044B\u043C\u0438
      \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
      \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C\u044E
      \u043A \u0432\u0440\u0435\u0434\u0438\u0442\u0435\u043B\u044F\u043C \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
      \u0433\u0435\u043D\u0443 Bt."
