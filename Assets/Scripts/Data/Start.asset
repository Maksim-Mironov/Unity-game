  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E, \u0441\u0435\u0433\u043E\u0434\u043D\u044F
      \u043C\u044B \u0432\u043C\u0435\u0441\u0442\u0435 \u0433\u0435\u043D\u043D\u043E\u043C\u043E\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u0443\u0435\u043C
      \u043A\u0430\u0440\u0442\u043E\u0444\u0435\u043B\u044C \u0438 \u0441\u0434\u0435\u043B\u0430\u0435\u043C
      \u0435\u0433\u043E \u0431\u043E\u043B\u0435\u0435 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u043C
      \u043A \u043A\u0430\u043B\u043E\u0440\u0430\u0434\u0441\u043A\u043E\u043C\u0443
      \u0436\u0443\u043A\u0443."
