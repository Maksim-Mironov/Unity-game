  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0412 \u0449\u0435\u043B\u043E\u0447\u043D\u043E\u0439 \u0441\u0440\u0435\u0434\u0435
      \u043A\u0438\u0448\u0435\u0447\u043D\u0438\u043A\u0430 \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u043E\u0433\u043E
      \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442 \u0430\u043A\u0442\u0438\u0432\u0430\u0446\u0438\u044F
      \u0431\u0435\u043B\u043A\u0430, \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435
      \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0438\u0440\u0443\u0435\u0442\u0441\u044F
      \u0432 \u0442\u043E\u043A\u0441\u0438\u043D.\r"
