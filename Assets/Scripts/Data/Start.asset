  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0412\u044B\u0431\u043E\u0440 \u0433\u0435\u043D\u0430: \u0413\u0435\u043D
      Bt \u0432\u044B\u0434\u0435\u043B\u044F\u0435\u0442\u0441\u044F \u0438\u0437
      \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u0438 Bacillus thuringiensis \u0438
      \u043F\u043E\u0434\u0433\u043E\u0442\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0434\u043B\u044F \u0432\u0441\u0442\u0430\u0432\u043A\u0438. \u041E\u0431\u044B\u0447\u043D\u043E
      \u043E\u043D \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F
      \u0432 \u0432\u0435\u043A\u0442\u043E\u0440 \u2013 \u044D\u0442\u043E \u043C\u043E\u043B\u0435\u043A\u0443\u043B\u0430,
      \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u0443\u0434\u0435\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F
      \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0430 \u0433\u0435\u043D\u0430."
