    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041E\u0442\u0431\u043E\u0440 \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0430\u043D\u0442\u043E\u0432:
      \u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0435\u043B\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
      \u043E\u0442\u0431\u043E\u0440\u0430 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
      \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0438 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
      \u043A \u0430\u043D\u0442\u0438\u0431\u0438\u043E\u0442\u0438\u043A\u0430\u043C)
      \u0432\u044B\u0431\u0438\u0440\u0430\u044E\u0442\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
      \u0442\u0435 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u0443\u0441\u043F\u0435\u0448\u043D\u043E \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0438
      \u0433\u0435\u043D Bt."
