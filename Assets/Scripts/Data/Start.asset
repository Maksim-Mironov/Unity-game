  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0412\u0441\u0442\u0430\u0432\u043A\u0430 \u044D\u0442\u043E\u0433\u043E
      \u0433\u0435\u043D\u0430 \u0432 \u043C\u043E\u0434\u0435\u043B\u044C\u043D\u044B\u0439
      \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
      \u0432 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F, \u043E\u0431\u044B\u0447\u043D\u043E
      \u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438."
