  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0413\u0435\u043D Bt \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
      \u0441\u043E\u0431\u043E\u0439 \u0443\u0447\u0430\u0441\u0442\u043E\u043A \u0414\u041D\u041A,
      \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0439 \u0438\u0437 \u043F\u043E\u0447\u0432\u0435\u043D\u043D\u043E\u0439
      \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u0438 Bacilluc thuringiensis."
