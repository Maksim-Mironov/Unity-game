  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0412\u0435\u0440\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F \u0438
      \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435: \u041F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0435
      \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u044E\u0442\u0441\u044F
      \u043D\u0430 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
      \u0433\u0435\u043D\u0430 Bt \u0438 \u0435\u0433\u043E \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u0443\u044E
      \u044D\u043A\u0441\u043F\u0440\u0435\u0441\u0441\u0438\u044E. \u042D\u0442\u043E
      \u043C\u043E\u0436\u0435\u0442 \u0432\u043A\u043B\u044E\u0447\u0430\u0442\u044C
      \u043C\u043E\u043B\u0435\u043A\u0443\u043B\u044F\u0440\u043D\u044B\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
      \u0438 \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
      \u043D\u0430 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C
      \u043A \u0432\u0440\u0435\u0434\u0438\u0442\u0435\u043B\u044F\u043C."
    Red: 1
