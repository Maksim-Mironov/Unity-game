  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041E\u0447\u0438\u0441\u0442\u043A\u0430 - \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0435
      \u043D\u0443\u043A\u043B\u0435\u0438\u043D\u043E\u0432\u044B\u0435 \u043A\u0438\u0441\u043B\u043E\u0442\u044B
      \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043E\u0447\u0438\u0449\u0435\u043D\u044B \u0434\u043B\u044F \u0443\u0434\u0430\u043B\u0435\u043D\u0438\u044F
      \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0445\u0441\u044F \u0437\u0430\u0433\u0440\u044F\u0437\u043D\u0435\u043D\u0438\u0439.
      \u042D\u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u0432\u043A\u043B\u044E\u0447\u0430\u0442\u044C
      \u043E\u0441\u0430\u0436\u0434\u0435\u043D\u0438\u0435 \u0441 \u044D\u0442\u0430\u043D\u043E\u043B\u043E\u043C,
      \u043C\u0435\u043C\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438
      \u0438\u043B\u0438 \u043A\u043E\u043B\u043E\u043D\u043A\u0438 \u0434\u043B\u044F
      \u043E\u0447\u0438\u0441\u0442\u043A\u0438."
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
