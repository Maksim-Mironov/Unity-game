  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0411\u0430\u043A\u0442\u0435\u0440\u0438\u0438 \u0431\u044B\u043B\u0438
      \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u044B \u0432 \u0441\u043E\u043B\u0435\u0432\u043E\u0439
      \u0440\u0430\u0441\u0442\u0432\u043E\u0440, \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0438\u0439
      \u0438\u0437 5 \u0433\u0440\u0430\u043C\u043C \u0446\u0438\u0442\u0440\u0430\u0442\u0430
      \u043D\u0430\u0442\u0440\u0438\u044F \"Na3C6H5O7\", 1 \u0433\u0440\u0430\u043C\u043C\u0430
      \u0441\u0443\u043B\u044C\u0444\u0430\u0442\u0430 \u0430\u043C\u043C\u043E\u043D\u0438\u044F
      \"(NH4)2SO4)\", 0.5 \u0433\u0440\u0430\u043C\u043C \u0434\u0438\u0433\u0438\u0434\u0440\u043E\u0444\u043E\u0441\u0444\u0430\u0442\u0430
      \u043A\u0430\u043B\u0438\u044F \"KH2PO4\", 0.5 \u0433\u0440\u0430\u043C\u043C
      \u0445\u043B\u043E\u0440\u0438\u0434\u0430 \u043D\u0430\u0442\u0440\u0438\u044F
      \"NaCl\" \u0438 1 \u043B\u0438\u0442\u0440\u0430 \u0434\u0438\u0441\u0442\u0438\u043B\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
      \u0432\u043E\u0434\u044B."
