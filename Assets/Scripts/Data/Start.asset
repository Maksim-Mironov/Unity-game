    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0425\u0440\u0430\u043D\u044F\u0442\u0441\u044F \u044D\u043A\u0441\u0442\u0440\u0430\u0433\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0435
      \u043D\u0443\u043A\u043B\u0435\u0438\u043D\u043E\u0432\u044B\u0435 \u043A\u0438\u0441\u043B\u043E\u0442\u044B
      \u043F\u0440\u0438 \u043D\u0438\u0437\u043A\u0438\u0445 \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0430\u0445
      \u0434\u043B\u044F \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
      \u0438\u0445 \u0434\u0435\u0433\u0440\u0430\u0434\u0430\u0446\u0438\u0438."
