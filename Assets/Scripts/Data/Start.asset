  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041B\u0438\u0437\u0438\u0441 \u043A\u043B\u0435\u0442\u043E\u043A -
      \u0430\u043F\u043F\u0430\u0440\u0430\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0440\u0435\u0430\u0433\u0435\u043D\u0442\u044B
      (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440: \u0441\u043E\u043B\u044F\u043D\u044B\u0435
      \u0440\u0430\u0441\u0442\u0432\u043E\u0440\u044B), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u043F\u043E\u043C\u043E\u0433\u0430\u044E\u0442 \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u044C
      \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u044B\u0435 \u043C\u0435\u043C\u0431\u0440\u0430\u043D\u044B
      \u0438 \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0430\u044E\u0442 \u043D\u0443\u043A\u043B\u0435\u0438\u043D\u043E\u0432\u044B\u0435
      \u043A\u0438\u0441\u043B\u043E\u0442\u044B."
