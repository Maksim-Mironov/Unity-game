  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041F\u0440\u043E\u0446\u0435\u0441\u0441 \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
      Bt-\u0442\u043E\u043A\u0441\u0438\u043D\u0430 \u043D\u0430 \u0432\u0440\u0435\u0434\u0438\u0442\u0435\u043B\u0435\u0439
      \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442 \u043F\u043E \u0447\u0451\u0442\u043A\u043E
      \u043E\u043F\u0440\u0435\u0434\u0438\u043B\u0451\u043D\u043D\u043E\u043C\u0443
      \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0443. \u041F\u043E\u0441\u043B\u0435
      \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u043E\u0435
      \u043F\u043E\u0435\u0434\u0430\u0435\u0442 \u0447\u0430\u0441\u0442\u0438 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F,
      \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0435 Bt-\u0431\u0435\u043B\u043E\u043A,
      \u043E\u043D \u043F\u043E\u043F\u0430\u0434\u0430\u0435\u0442 \u0432 \u043F\u0438\u0449\u0435\u0432\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
      \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0432\u0440\u0435\u0434\u0438\u0442\u0435\u043B\u044F. "
    Red: 1
