  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u042D\u0442\u0430 \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u044F \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
      \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E
      \u0441\u0438\u043D\u0442\u0435\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0431\u0435\u043B\u043A\u0438, \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0435
      \u0442\u043E\u043A\u0441\u0438\u0447\u043D\u043E\u0435 \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
      \u043D\u0430 \u043E\u043F\u0440\u0435\u0434\u0438\u043B\u0451\u043D\u043D\u044B\u0435
      \u0432\u0438\u0434\u044B \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u044B\u0445."
    Red: 1
    Green: 1
    Blue: 1
    Alfa: 1
    Object: 0
    NumberObject: 0
    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
      \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u0438\u0434\u0435\u043D\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0438 \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C \u0433\u0435\u043D,
      \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u0437\u0430 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E
      \u044D\u0442\u043E\u0433\u043E \u0438\u043D\u0441\u0435\u043A\u0442\u0438\u0446\u0438\u0434\u043D\u043E\u0433\u043E
      \u0431\u0435\u043B\u043A\u0430, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
      \u043E\u043D \u0431\u044B\u043B \u0443\u0441\u043F\u0435\u0448\u043D\u043E
      \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D \u0432
      \u0433\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043A\u043E\u0434
      \u043A\u0430\u0440\u0442\u043E\u0444\u0435\u043B\u044F. \r"
    Red: 1
