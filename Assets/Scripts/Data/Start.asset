  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041C\u0438\u043D\u0435\u0440\u0430\u043B\u044B \u0438 \u0432\u0438\u0442\u0430\u043C\u0438\u043D\u044B
