  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041E\u043D\u0438 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u044B \u0432
      \u0446\u0438\u0442\u0440\u0430\u0442\u043D\u043E-\u0430\u043C\u043C\u043E\u043D\u0438\u0435\u0432\u0443\u044E
      \u0441\u0440\u0435\u0434\u0443. \u0426\u0438\u0442\u0440\u0430\u0442\u043D\u043E-\u0430\u043C\u043C\u043E\u043D\u0438\u0439\u043D\u0430\u044F
      \u0441\u0440\u0435\u0434\u0430 \u2014 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
      \u043F\u0438\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u0441\u0440\u0435\u0434\u0430,
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u0430\u044F \u0434\u043B\u044F
      \u043A\u0443\u043B\u044C\u0442\u0438\u0432\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
      \u043C\u0438\u043A\u0440\u043E\u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u043E\u0432,
      \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \u0431\u0430\u043A\u0442\u0435\u0440\u0438\u0438
      \u0438 \u0433\u0440\u0438\u0431\u044B."
    Red: 1
    Green: 1
