    Mission: 1
  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u041C\u043E\u043D\u0438\u0442\u043E\u0440\u0438\u043D\u0433 \u0438 \u043E\u0446\u0435\u043D\u043A\u0430:
      \u041F\u043E\u0441\u043B\u0435 \u0432\u043D\u0435\u0434\u0440\u0435\u043D\u0438\u044F
      \u0432 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0443 \u0438\u043B\u0438
      \u0432 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435 \u0442\u0430\u043A\u0436\u0435
      \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043C\u043E\u043D\u0438\u0442\u043E\u0440\u0438\u043D\u0433
      \u0435\u0433\u043E \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0432
      \u044D\u043A\u043E\u0441\u0438\u0441\u0442\u0435\u043C\u0435, \u0447\u0442\u043E\u0431\u044B
      \u043E\u0446\u0435\u043D\u0438\u0442\u044C \u0435\u0433\u043E \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
      \u043D\u0430 \u0441\u0440\u0435\u0434\u0443 \u0438 \u043F\u043E\u043B\u0435\u0437\u043D\u044B\u0435
      \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u044B."
    Red: 1
    Green: 1
