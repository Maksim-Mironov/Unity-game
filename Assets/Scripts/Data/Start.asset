  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u0422\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F
      \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F: Agrobacterium \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0430
      \u0432\u043D\u0435\u0434\u0440\u044F\u0442\u044C \u0441\u0432\u043E\u0439 \u0433\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B (\u0432\u043A\u043B\u044E\u0447\u0430\u044F
      \u0433\u0435\u043D Bt) \u0432 \u043A\u043B\u0435\u0442\u043A\u0443 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F.
      \u0414\u0430\u043B\u0435\u0435, \u043A\u043B\u0435\u0442\u043A\u0438 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0439
      \u043F\u043E\u043C\u0435\u0449\u0430\u044E\u0442\u0441\u044F \u043D\u0430 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
      \u043F\u0438\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E \u0441\u0440\u0435\u0434\u0443,
      \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0438\u043C\u0443\u043B\u0438\u0440\u0443\u0435\u0442
      \u0440\u0435\u0433\u0435\u043D\u0435\u0440\u0430\u0446\u0438\u044E \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F
      \u0438\u0437 \u043A\u043E\u043B\u043E\u043D\u0438\u0438 \u043A\u043B\u0435\u0442\u043E\u043A."
    Red: 1
    Green: 1
    Blue: 1
