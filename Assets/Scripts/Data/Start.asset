  - _name: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439"
    _text: "\u042D\u0442\u043E\u0442 \u0442\u043E\u043A\u0441\u0438\u043D \u0430\u0442\u0430\u043A\u0443\u0435\u0442
      \u0441\u0442\u0435\u043D\u043A\u0438 \u043A\u0438\u0448\u0435\u0447\u043D\u0438\u043A\u0430
      \u0432\u0440\u0435\u0434\u0438\u0442\u0435\u043B\u044F, \u0447\u0442\u043E
      \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442 \u043A \u0438\u0445 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u044E
      \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439 \u0433\u0438\u0431\u0435\u043B\u0438
      \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u043E\u0433\u043E \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
      \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0447\u0430\u0441\u043E\u0432
      \u0438\u043B\u0438 \u0434\u043D\u0435\u0439."
