    2 (FGF2) \u2014 \u043F\u0440\u0438 \u0432\u044B\u0440\u0430\u0449\u0438\u0432\u0430\u043D\u0438\u0438
    \u043A\u043B\u0435\u0442\u043E\u043A. \u041E\u043D\u0438 \u043C\u043E\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0433\u0435\u043D\u043E\u043C \u0441\u0442\u0432\u043E\u043B\u043E\u0432\u044B\u0445
    \u043A\u043B\u0435\u0442\u043E\u043A \u043C\u044B\u0448\u0446 \u043A\u043E\u0440\u043E\u0432\u044B
    (immortalized bovine satellite cells, iBSC) \u0442\u0430\u043A, \u0447\u0442\u043E
    \u0442\u0435 \u0441\u0430\u043C\u0438 \u043D\u0430\u0447\u0430\u043B\u0438 \u0441\u0438\u043D\u0442\u0435\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
