    \u0438\u043B\u0438 \u0436\u0435 \u043C\u043E\u0433\u043B\u0438 \u0432\u043E\u043E\u0431\u0449\u0435
    \u0431\u0435\u0437 \u043D\u0435\u0433\u043E \u043E\u0431\u043E\u0439\u0442\u0438\u0441\u044C.
    \u042D\u0442\u0438 \u043A\u043B\u0435\u0442\u043A\u0438 \u0445\u043E\u0440\u043E\u0448\u043E
